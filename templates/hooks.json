{
  "_source": "Each key is the marker string gabe-init Step 2 greps for. Each value is the exact hook-array entry to append under the matching settings.json event array (SessionStart / PreToolUse / PostToolUse / Stop). Hook scripts ship from the suite repo (scripts/hooks/kdbp/) via install.sh. Never edit the command strings by hand \u2014 reinstall via the suite if a hook needs to change. Retired in A2 KDBP-lite: the LEDGER.md per-tool-call writer and the KNOWLEDGE session-awareness hook.",
  "KDBP Active": {
    "event": "SessionStart",
    "entry": {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$ECC_ROOT/scripts/hooks/kdbp/session-kdbp-active.sh\"",
          "timeout": 5
        }
      ]
    }
  },
  "ACTIVE PLAN": {
    "event": "SessionStart",
    "entry": {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$ECC_ROOT/scripts/hooks/kdbp/session-plan-awareness.sh\"",
          "timeout": 5
        }
      ]
    }
  },
  "KDBP CHECKPOINT": {
    "event": "PreToolUse",
    "entry": {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$ECC_ROOT/scripts/hooks/kdbp/pre-checkpoint.sh\"",
          "timeout": 5
        }
      ]
    }
  },
  "STRUCTURE:": {
    "event": "PostToolUse",
    "entry": {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$ECC_ROOT/scripts/hooks/kdbp/post-structure-warning.sh\"",
          "timeout": 5
        }
      ]
    }
  },
  "SESSION-END REMINDER": {
    "event": "Stop",
    "entry": {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$ECC_ROOT/scripts/hooks/kdbp/stop-session-reminder.sh\"",
          "timeout": 10
        }
      ]
    }
  }
}
